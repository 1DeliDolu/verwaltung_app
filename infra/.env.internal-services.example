MAIL_DOMAIN=verwaltung.local
MAIL_HOSTNAME=mail
MAIL_FQDN=mail.verwaltung.local
OVERRIDE_HOSTNAME=mail.verwaltung.local
DMS_DEBUG=0
ENABLE_IMAP=1
ENABLE_POP3=0
ENABLE_CLAMAV=0
ENABLE_FAIL2BAN=1
SSL_TYPE=manual
SSL_CERT_PATH=/etc/letsencrypt/live/mail.verwaltung.local/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/mail.verwaltung.local/privkey.pem
POSTMASTER_ADDRESS=postmaster@verwaltung.local
TZ=Europe/Berlin
SAMBA_LOG_LEVEL=0
WSDD2_ENABLE=0
