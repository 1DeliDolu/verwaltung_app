    <diagram id="workflows" name="03 Core Workflows">
        <mxGraphModel dx="1002" dy="324" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="2" value="Verwaltung App&#xa;Core Workflows" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0f172a;strokeColor=#0f172a;fontColor=#ffffff;fontStyle=1;fontSize=20;" parent="1" vertex="1">
                    <mxGeometry x="40" y="20" width="340" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="3" value="Page 1 showed boundaries. This page focuses on the main business flows implemented by the controllers and services in the current codebase." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#94a3b8;fontColor=#334155;fontSize=12;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="410" y="20" width="1160" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="4" value="1. IT-first provisioning" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#3b82f6;fontStyle=1;fontSize=17;align=left;spacingLeft=12;" parent="1" vertex="1">
