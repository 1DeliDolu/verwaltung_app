                <mxCell id="6" value="DepartmentController::storeManagedPerson&#xa;POST /departments/{slug}/people" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="280" y="150" width="250" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="7" value="DepartmentService::createManagedPerson&#xa;assert department authority&#xa;validate temporary password&#xa;call AuthService::assertPasswordStrength" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#ea580c;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="580" y="140" width="320" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="8" value="users + department_user&#xa;create provisioned account&#xa;set created_by_user_id&#xa;require first password change" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="950" y="145" width="250" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="9" value="First login&#xa;AuthService::attempt&#xa;redirect to /password/change if required" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1260" y="150" width="230" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="10" value="User::updatePassword&#xa;clear password_change_required_at&#xa;set password_changed_at" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="1530" y="150" width="190" height="90" as="geometry"/>
