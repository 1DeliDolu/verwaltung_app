    <diagram id="application-layers" name="02 Application Layers">
        <mxGraphModel dx="1002" dy="324" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
