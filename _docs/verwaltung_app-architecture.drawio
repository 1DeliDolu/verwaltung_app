                    <mxGeometry x="70" y="380" width="150" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="13" value="DepartmentController::storeEmployee&#xa;POST /departments/{slug}/employees" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="270" y="370" width="250" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="14" value="DepartmentService::createEmployee&#xa;only HR + manager&#xa;user must already be provisioned by IT&#xa;generate employee number" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#ea580c;fontSize=14;" parent="1" vertex="1">
