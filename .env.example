APP_NAME="Verwaltung App"
APP_ENV=local
APP_DEBUG=true
APP_DEMO_MODE=true
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_FROM_ADDRESS=probe@verwaltung.demo
MAIL_FROM_NAME="Verwaltung Probe"
MAIL_TEST_RECIPIENT=admin@verwaltung.demo
MAIL_AUDIT_REPORT_ADMIN_EMAIL=admin@verwaltung.local
MAIL_AUDIT_REPORT_RECIPIENTS=admin@verwaltung.demo
# Optional local/test hooks
MAIL_CAPTURE_PATH=
MAIL_AUDIT_REPORT_NOW=
MAILHOG_API_URL=http://127.0.0.1:8025/api/v2/messages

AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_DECAY_SECONDS=900
AUTH_MFA_EMAIL_CHALLENGE_ROLES=admin
AUTH_MFA_EMAIL_CHALLENGE_EXPIRE_SECONDS=600
AUTH_PASSWORD_RESET_EXPIRE_SECONDS=3600
AUTH_PASSWORD_RESET_REQUEST_MAX_ATTEMPTS=3
AUTH_PASSWORD_RESET_REQUEST_DECAY_SECONDS=900

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=verwaltung_app
DB_USERNAME=root
DB_PASSWORD=
